# ══════════════════════════════════════════════
#  Insul-Techs Lead Agents — Configuración
# ══════════════════════════════════════════════

# ── Telegram ──────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=-1001234567890

# ── Contactos GC ──────────────────────────────
# Carpeta donde están tus archivos .csv de contactos
# (por defecto: contacts/ en la raíz del proyecto)
CONTACTS_DIR=contacts

# Umbral de similitud para fuzzy matching (0.0 - 1.0)
# 0.72 = tolerante (recomendado)
# 0.85 = estricto (menos falsos positivos)
# 0.60 = muy tolerante (más matches, posibles errores)
FUZZY_THRESHOLD=0.72

# ── Agentes — Activar/Desactivar ──────────────
# true = activo, false = desactivado
AGENT_PERMITS=true
AGENT_SOLAR=true
AGENT_RODENTS=true
AGENT_FLOOD=true

# ── Intervalos de ejecución (minutos) ─────────
INTERVAL_PERMITS=60
INTERVAL_SOLAR=60
INTERVAL_RODENTS=120
INTERVAL_FLOOD=30
