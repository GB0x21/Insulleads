# ─────────────────────────────────────────
#  INSUL-TECHS LEAD AGENTS — CONFIGURATION
# ─────────────────────────────────────────
# 1. Copia este archivo como .env
# 2. Rellena tus valores reales
# 3. Nunca subas .env a GitHub

# ── TELEGRAM ──────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=-1001234567890   # ID del grupo o chat donde llegan los leads

# ── AGENTES ACTIVOS (true/false) ──────────
AGENT_PERMITS=true        # Permisos de construcción
AGENT_SOLAR=true          # Instalaciones solares
AGENT_RODENTS=true        # Reportes 311 de roedores
AGENT_FLOOD=true          # Alertas post-inundación NOAA

# ── INTERVALOS DE REVISIÓN (minutos) ──────
INTERVAL_PERMITS=60
INTERVAL_SOLAR=60
INTERVAL_RODENTS=120
INTERVAL_FLOOD=30

# ── ZONA GEOGRÁFICA ───────────────────────
TARGET_COUNTIES=San Francisco,Alameda,Contra Costa,Santa Clara,San Mateo,Marin,Sonoma,Napa
